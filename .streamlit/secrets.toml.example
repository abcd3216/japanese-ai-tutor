# ============================================================
# Streamlit Cloud「Secrets」範本
#
# 本機開發：不需要這個檔，直接用專案根目錄的 .env 就好。
# 雲端部署：把下面內容（填入真正的值）貼到
#           Streamlit Cloud → 你的 App → Settings → Secrets 裡。
#
# ⚠️ 真正的 secrets.toml 已被 .gitignore 排除，不會上傳。
# ============================================================

GEMINI_API_KEY = "你的_Gemini_金鑰"
SQL_SERVER   = "your-server.database.windows.net"
SQL_DATABASE = "your-database"
SQL_USERNAME = "your-username"
SQL_PASSWORD = "your-password"

# 雲端 Linux 會自動用 FreeTDS，通常不用設定這一行。
# 若部署後連不上資料庫，可嘗試取消註解、或改成其他驅動名稱：
# SQL_ODBC_DRIVER = "FreeTDS"
